# LandBiznes Backend Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=logs/app.log

# API Configuration
API_TITLE=LandBiznes Backend API
API_VERSION=1.0.0
API_PREFIX=/api/v1

# CORS Configuration
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:8000"]

# ============================================================================
# DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=landbiznes_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=50

# ============================================================================
# JWT & SECURITY
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=60

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=["pdf", "jpg", "jpeg", "png", "doc", "docx"]
UPLOAD_DIR=./uploads

# ============================================================================
# BLOCKCHAIN (SOLANA)
# ============================================================================
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=your-program-id
BLOCKCHAIN_ENABLED=false

# ============================================================================
# EMAIL
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@landbiznes.com
EMAIL_ENABLED=false

# ============================================================================
# AI/FRAUD DETECTION
# ============================================================================
AI_FRAUD_DETECTION_ENABLED=false
AI_MODEL_PATH=./models/fraud_detector.pkl

# ============================================================================
# PAGINATION
# ============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# MONITORING
# ============================================================================
SENTRY_DSN=
SENTRY_ENABLED=false
ENABLE_METRICS=true
